# Скопируйте в .env в корне репозитория: cp .env.example .env
# Файл .env не коммитится в git.

POSTGRES_DB=msgs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# URL API для сборки фронтенда в Docker (доступ с браузера хоста)
VITE_API_BASE_URL=http://localhost:5000/api

# --- docker-compose.release.yml (продакшн из GHCR) ---
# GHCR_OWNER=your-github-username
# APP_VERSION=v1.0.0
# JWT_SECRET_KEY=change-me-in-production

# SMTP (опционально, для подтверждения email)
# Smtp__FromEmail=your@gmail.com
# Smtp__AppPassword=xxxx xxxx xxxx xxxx
